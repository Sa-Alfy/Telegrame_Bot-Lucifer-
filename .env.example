# ============================================
# Telegram Bot - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your real keys:
#   cp .env.example .env
#
# NEVER share your .env file or commit it to Git!
# ============================================

# Your Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API Key for AI Chat (get free at https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face API Key for AI Image Generation (get free at https://huggingface.co/settings/tokens)
IMAGE_GEN_KEY=your_huggingface_api_key_here

# OpenWeatherMap API Key (get free at https://openweathermap.org/api)
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here

# Your Telegram User ID for admin-only commands (send /debug to the bot to find your ID)
ADMIN_ID=your_telegram_user_id_here

# Gemini API Key (optional, get at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
